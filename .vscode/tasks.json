{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Factory: 1 - Setup Python",
      "type": "shell",
      "command": "python3 -m venv .venv && .venv/bin/python -m pip install --upgrade pip && .venv/bin/python -m pip install -e '.[dev]'",
      "problemMatcher": []
    },
    {
      "label": "Factory: 2 - Test connection",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory doctor --site '${input:site}'",
      "problemMatcher": []
    },
    {
      "label": "Factory: 3 - Lint Markdown",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory lint --site '${input:site}'",
      "problemMatcher": []
    },
    {
      "label": "Factory: 4 - Preview sync plan",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory plan --site '${input:site}'",
      "problemMatcher": []
    },
    {
      "label": "Factory: 5 - Push site",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory push --site '${input:site}'",
      "problemMatcher": []
    },
    {
      "label": "Factory: Pull safe remote changes",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory pull --site '${input:site}'",
      "problemMatcher": []
    },
    {
      "label": "Factory: Verify live records",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory verify --site '${input:site}'",
      "problemMatcher": []
    },
    {
      "label": "Factory: Plan all sites",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory plan --all",
      "problemMatcher": []
    },
    {
      "label": "Factory: Push all sites",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory push --all",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: List menu",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools list",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Image fixer (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run image-fixer --site '${input:site}'",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: External linker (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run external-linker --site '${input:site}'",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Internal linker (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run internal-linker --site '${input:site}'",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Site dashboard",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run site-dashboard --site '${input:site}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Featured images fix (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run featured-image-fixer --site '${input:site}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Featured images then SEO audit",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run featured-image-fixer --site '${input:site}' && .venv/bin/python -m wp_factory tools run seo-audit --site '${input:site}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: SEO audit (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run seo-audit --site '${input:site}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Readability (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run readability --site '${input:site}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Link health (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run link-health --site '${input:site}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Schema suggest (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run schema-suggest --site '${input:site}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Publish readiness (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run publish-readiness --site '${input:site}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Content overlap map (site)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run content-overlap --site '${input:site}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Check selected draft for overlap",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run content-overlap --site '${input:site}' --target '${file}' --open",
      "problemMatcher": []
    },
    {
      "label": "Factory Tools: Run selected file with tool",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory tools run '${input:factoryTool}' --site '${input:site}' --target '${file}'",
      "problemMatcher": []
    },
    {
      "label": "Factory: Create website folder(s)",
      "type": "shell",
      "command": ".venv/bin/python -m wp_factory new-site ${input:newSites}",
      "problemMatcher": []
    },
    {
      "label": "Tests: Run Core Stability Suite",
      "type": "process",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "-m",
        "not live",
        "--cov=wp_factory",
        "--cov-branch",
        "--cov-report=term-missing",
        "--cov-fail-under=30"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "site",
      "type": "promptString",
      "description": "Folder name under websites/",
      "default": "example.com"
    },
    {
      "id": "newSites",
      "type": "promptString",
      "description": "One or more domain folders under websites/, separated by spaces",
      "default": "new-domain.com another-domain.com"
    },
    {
      "id": "factoryTool",
      "type": "pickString",
      "description": "Tool to run against the active editor file",
      "options": [
        "image-fixer",
        "external-linker",
        "internal-linker",
        "site-dashboard",
        "featured-image-fixer",
        "seo-audit",
        "readability",
        "link-health",
        "schema-suggest",
        "publish-readiness",
        "content-overlap"
      ],
      "default": "featured-image-fixer"
    }
  ]
}
