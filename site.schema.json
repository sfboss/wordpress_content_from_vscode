{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WordPress Content Factory site config",
  "type": "object",
  "required": ["site", "content"],
  "properties": {
    "site": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {"type": "string"},
        "default_status": {"enum": ["draft", "pending", "private", "publish", "future"]},
        "timeout_seconds": {"type": "integer", "minimum": 1}
      }
    },
    "content": {
      "type": "object",
      "properties": {
        "strict_alt_text": {"type": "boolean"},
        "delete_remote": {"const": false}
      }
    }
  }
}

